# backend/.env - ADD these lines
DATABASE_URL="postgresql://postgres:password123@localhost:5432/codecollab_dev"
REDIS_URL="redis://localhost:6379"
MONGODB_URL="mongodb://admin:password123@localhost:27017/codecollab?authSource=admin"

# JWT Secrets (generate these with random strings)
JWT_SECRET="your-super-secret-jwt-key-256-bits-long-random-string"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-256-bits-long-random-string"

# Google OAuth (you'll get these from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# Server settings
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"